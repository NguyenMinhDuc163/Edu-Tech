# Local fastlane .env
# Copy this file to ios/fastlane/.env for local TestFlight upload.
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_KEY_FILEPATH=./fastlane/AuthKey_XXXXXXXXXX.p8

# GitHub Actions repository secrets used by .github/workflows/ios-testflight.yml
# Do not put these base64 values in ios/fastlane/.env.
#
# APP_STORE_CONNECT_KEY_ID=
# APP_STORE_CONNECT_ISSUER_ID=
# APP_STORE_CONNECT_API_KEY_P8=
# IOS_DISTRIBUTION_CERTIFICATE_P12_BASE64=
# IOS_DISTRIBUTION_CERTIFICATE_PASSWORD=
# IOS_APPSTORE_PROVISIONING_PROFILE_BASE64=
